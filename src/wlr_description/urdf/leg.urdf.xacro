<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Five-bar linkage leg macro.
       side: "left" or "right", y_sign: +1 left / -1 right, parent: base_link.
       Front chain: A(hip_front) B C.  Rear chain: E(hip_rear) D C wheel.
       Closure constraint added in gazebo.xacro.
  -->

  <xacro:property name="l1" value="0.07"/>
  <xacro:property name="l2" value="0.147"/>
  <xacro:property name="l3" value="0.147"/>
  <xacro:property name="l4" value="0.07"/>
  <xacro:property name="l5" value="0.123"/>
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width" value="0.025"/>
  <xacro:property name="link_radius" value="0.008"/>
  <xacro:property name="body_width" value="0.155"/>

  <!-- hip_init: rpy pitch offset on hip joint origins.
       At URDF=0 the five-bar is in an extended configuration.
       Combined with knee_init offsets below, chain endpoints are
       geometrically coincident — the FiveBarClosure plugin then
       enforces the constraint at runtime. -->
  <xacro:property name="hip_init_front" value="-0.7"/>
  <xacro:property name="hip_init_rear" value="0.7"/>

  <!-- knee_init: pitch offsets on knee joint origins so that at URDF=0
       the front and rear chain endpoints (foot_front, foot_rear) are
       geometrically coincident, enabling the spring-damper closure plugin.
       Solved numerically: with hip_init=±0.7, knee_init=±0.5882 gives
       foot endpoints coincident at (0, -0.1996) relative to body center. -->
  <xacro:property name="knee_init_front" value="0.5882"/>
  <xacro:property name="knee_init_rear" value="-0.5882"/>

  <!-- Masses from thesis Table 2.1 -->
  <xacro:property name="upper_link_mass" value="0.039"/>
  <xacro:property name="lower_link_mass" value="0.072"/>
  <xacro:property name="wheel_mass" value="0.340"/>

  <!-- Y offset from body center to hip joint -->
  <xacro:property name="hip_y_offset" value="${body_width/2 + 0.01}"/>

  <xacro:macro name="cylinder_inertia" params="mass radius length">
    <inertia
      ixx="${mass*(3*radius*radius+length*length)/12}"
      ixy="0" ixz="0"
      iyy="${mass*(3*radius*radius+length*length)/12}"
      iyz="0"
      izz="${mass*radius*radius/2}"/>
  </xacro:macro>

  <xacro:macro name="link_inertia" params="mass length">
    <!-- Thin cylinder along Z: ixx=iyy=m(3r^2+L^2)/12, izz=mr^2/2 -->
    <inertia
      ixx="${mass*(3*link_radius*link_radius+length*length)/12}"
      ixy="0" ixz="0"
      iyy="${mass*(3*link_radius*link_radius+length*length)/12}"
      iyz="0"
      izz="${mass*link_radius*link_radius/2}"/>
  </xacro:macro>

  <xacro:macro name="leg" params="side y_sign parent">

    <!-- ==================== FRONT CHAIN (A -> B -> C_front) ==================== -->

    <!-- Front hip joint (A) - ACTUATED -->
    <joint name="${side}_hip_front_joint" type="revolute">
      <parent link="${parent}"/>
      <child link="${side}_upper_front"/>
      <origin xyz="${l5/2} ${y_sign * hip_y_offset} 0" rpy="0 ${hip_init_front} 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.5" upper="1.5" effort="10.0" velocity="20.0"/>
      <dynamics damping="0.01" friction="0.005"/>
    </joint>

    <!-- Upper front link (A-B, length l1) -->
    <link name="${side}_upper_front">
      <visual>
        <origin xyz="0 0 ${-l1/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${link_radius}" length="${l1}"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-l1/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${link_radius}" length="${l1}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-l1/2}" rpy="0 0 0"/>
        <mass value="${upper_link_mass}"/>
        <xacro:link_inertia mass="${upper_link_mass}" length="${l1}"/>
      </inertial>
    </link>

    <!-- Front knee joint (B) - PASSIVE -->
    <joint name="${side}_knee_front_joint" type="revolute">
      <parent link="${side}_upper_front"/>
      <child link="${side}_lower_front"/>
      <origin xyz="0 0 ${-l1}" rpy="0 ${knee_init_front} 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-3.14159" upper="3.14159" effort="0" velocity="20.0"/>
      <dynamics damping="0.005" friction="0.002"/>
    </joint>

    <!-- Lower front link (B-C, length l2) -->
    <link name="${side}_lower_front">
      <visual>
        <origin xyz="0 0 ${-l2/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${link_radius}" length="${l2}"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-l2/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${link_radius}" length="${l2}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-l2/2}" rpy="0 0 0"/>
        <mass value="${lower_link_mass}"/>
        <xacro:link_inertia mass="${lower_link_mass}" length="${l2}"/>
      </inertial>
    </link>

    <!-- Foot front (dummy link at C for closure) -->
    <joint name="${side}_foot_front_joint" type="fixed">
      <parent link="${side}_lower_front"/>
      <child link="${side}_foot_front"/>
      <origin xyz="0 0 ${-l2}" rpy="0 0 0"/>
    </joint>

    <link name="${side}_foot_front">
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
      </inertial>
    </link>

    <!-- ==================== REAR CHAIN (E -> D -> C_rear -> wheel) ==================== -->

    <!-- Rear hip joint (E) - ACTUATED -->
    <joint name="${side}_hip_rear_joint" type="revolute">
      <parent link="${parent}"/>
      <child link="${side}_upper_rear"/>
      <origin xyz="${-l5/2} ${y_sign * hip_y_offset} 0" rpy="0 ${hip_init_rear} 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.5" upper="1.5" effort="10.0" velocity="20.0"/>
      <dynamics damping="0.01" friction="0.005"/>
    </joint>

    <!-- Upper rear link (E-D, length l4) -->
    <link name="${side}_upper_rear">
      <visual>
        <origin xyz="0 0 ${-l4/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${link_radius}" length="${l4}"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-l4/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${link_radius}" length="${l4}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-l4/2}" rpy="0 0 0"/>
        <mass value="${upper_link_mass}"/>
        <xacro:link_inertia mass="${upper_link_mass}" length="${l4}"/>
      </inertial>
    </link>

    <!-- Rear knee joint (D) - PASSIVE -->
    <joint name="${side}_knee_rear_joint" type="revolute">
      <parent link="${side}_upper_rear"/>
      <child link="${side}_lower_rear"/>
      <origin xyz="0 0 ${-l4}" rpy="0 ${knee_init_rear} 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-3.14159" upper="3.14159" effort="0" velocity="20.0"/>
      <dynamics damping="0.005" friction="0.002"/>
    </joint>

    <!-- Lower rear link (D-C, length l3) -->
    <link name="${side}_lower_rear">
      <visual>
        <origin xyz="0 0 ${-l3/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${link_radius}" length="${l3}"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-l3/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${link_radius}" length="${l3}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-l3/2}" rpy="0 0 0"/>
        <mass value="${lower_link_mass}"/>
        <xacro:link_inertia mass="${lower_link_mass}" length="${l3}"/>
      </inertial>
    </link>

    <!-- Foot rear (endpoint of rear chain, where wheel attaches) -->
    <joint name="${side}_foot_rear_joint" type="fixed">
      <parent link="${side}_lower_rear"/>
      <child link="${side}_foot_rear"/>
      <origin xyz="0 0 ${-l3}" rpy="0 0 0"/>
    </joint>

    <link name="${side}_foot_rear">
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
      </inertial>
    </link>

    <!-- ==================== WHEEL ==================== -->

    <!-- Wheel joint at C point (attached to rear chain endpoint) -->
    <joint name="${side}_wheel_joint" type="continuous">
      <parent link="${side}_foot_rear"/>
      <child link="${side}_wheel"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.001" friction="0.001"/>
    </joint>

    <link name="${side}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <mass value="${wheel_mass}"/>
        <xacro:cylinder_inertia mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_width}"/>
      </inertial>
    </link>

  </xacro:macro>

</robot>
